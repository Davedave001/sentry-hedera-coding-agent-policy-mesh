# API container: server/index.ts (HTTP + WebSocket) and the MCP server share this
# image. Deploy with Coolify pointing at this Dockerfile, mapped to whichever
# domain your DNS actually has an A/CNAME record for (e.g. api-sentry.agentikiq.com
# — double-check the exact subdomain spelling against your DNS provider before
# assuming it matches any default in this repo), with a real .env (see
# .env.example) supplied via Coolify's environment variables UI — never bake
# secrets into the image.

FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY tsconfig.json ./
COPY server ./server
COPY mcp-server ./mcp-server
RUN npm run build

FROM node:22-alpine AS runtime
WORKDIR /app
ENV NODE_ENV=production
COPY package.json package-lock.json ./
RUN npm ci --omit=dev
COPY --from=build /app/dist/server ./dist/server
COPY policy.config.json ./policy.config.json

EXPOSE 8787
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s \
  CMD wget -qO- http://localhost:8787/health || exit 1

CMD ["node", "dist/server/index.js"]
