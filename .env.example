# Hedera
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.XXXXX
HEDERA_OPERATOR_KEY=YOUR_TESTNET_PRIVATE_KEY
HEDERA_AUDIT_TOPIC_ID=0.0.XXXXX

# Coding-agent providers (Case A)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Pricing / policy
HBAR_USD=0.06
PIPELINE_CAP_HBAR=50

# Server
PORT=8787
# Origin of the deployed frontend container — required for CORS once frontend and
# API are split across two domains (see Dockerfile.frontend / Dockerfile.api).
FRONTEND_ORIGIN=https://sentry-coding-policy-agent.agentikiq.com
